# ┌──────────────────────────────────────────────────────────┐
# │  Environment Variables — copy to .env and fill values   │
# │  NEVER commit .env to Git — add it to .gitignore        │
# └──────────────────────────────────────────────────────────┘

# ── Vercel (Frontend) ──
NEXT_PUBLIC_API_URL=https://your-render-app.onrender.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Render (Backend) ──
NODE_ENV=production
PORT=3001

# Email service (pick one: Resend, SendGrid, Nodemailer SMTP)
EMAIL_SERVICE=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# OR
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# OR SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Email addresses
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO=hrithikgh29@gmail.com

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Security
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Optional: Upstash Redis (for persistent rate limiting across deploys)
# UPSTASH_REDIS_REST_URL=https://xxxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxQ=

# Spotify hamaguri playlist widget (mobile homepage)
# Create app at https://developer.spotify.com/dashboard — Client Credentials only
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_PLAYLIST_ID=37i9dQZF1DX...  # public playlist ID from the Spotify URL
